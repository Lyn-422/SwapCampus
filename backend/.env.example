# SwapCampus 后端环境变量
# 复制此文件为 .env 并填写实际值
# cp .env.example .env

# Django
SECRET_KEY=change-me-to-a-random-string
DEBUG=True

# 数据库引擎（默认 sqlite，零配置；生产/CI 设为 mysql）
DB_ENGINE=sqlite

# MySQL 数据库（仅 DB_ENGINE=mysql 时需要）
DB_NAME=swapcampus
DB_USER=swapcampus
DB_PASSWORD=your_password_here
DB_HOST=127.0.0.1
DB_PORT=3306

# Redis（Channels）
REDIS_URL=redis://127.0.0.1:6379/0

# MinIO 对象存储
MINIO_ENDPOINT=127.0.0.1:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=swapcampus
